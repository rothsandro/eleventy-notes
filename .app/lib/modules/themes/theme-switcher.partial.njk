{% set id = uniqueId() %}

<div 
  class="theme-switcher" 
  x-data="themeSwitcher"
  x-cloak 
  lang="{% uiLang %}" 
  @keydown.escape.window="if (open) { closeMenu(); $event.preventDefault(); }"
>
  <button
    type="button"
    class="theme-switcher__button icon-btn"
    :aria-expanded="open"
    aria-haspopup="menu"
    aria-label="{{ 'theme_switcher.label' | t }}"
    @click="openMenu()"
    x-ref="button"
  >
    <span x-show="$store.appearance.theme === 'light'">{{ 'sun' | icon | safe }}</span>
    <span x-show="$store.appearance.theme === 'dark'">{{ 'moon' | icon | safe }}</span>
    <span x-show="$store.appearance.theme === 'system'">{{ 'monitor' | icon | safe }}</span>
  </button>

  <div
    class="theme-switcher__menu"
    x-show="open"
    x-transition
    @click.outside="closeMenu()"
    @keydown="handleMenuKeydown($event)"
    role="menu"
    aria-label="{{ 'theme_switcher.label' | t }}"
    x-ref="menu"
  >
    <button
      type="button"
      role="menuitemradio"
      :aria-checked="$store.appearance.theme === 'light'"
      :tabindex="$store.appearance.theme === 'light' ? 0 : -1"
      class="theme-switcher__menu-item"
      @click="selectTheme('light')"
      @keydown.arrow-down.prevent="focusNext(0)"
      @keydown.arrow-up.prevent="focusPrevious(0)"
      @keydown.enter.prevent="selectTheme('light')"
      @keydown.space.prevent="selectTheme('light')"
      @keydown.home.prevent="$refs.menu.querySelector('[role=menuitemradio]').focus()"
      @keydown.end.prevent="$refs.menu.querySelectorAll('[role=menuitemradio]')[2].focus()"
    >
      {{ 'sun' | icon | safe }}
      <span>{{ 'theme_switcher.options.light' | t }}</span>
      <span class="theme-switcher__check" x-show="$store.appearance.theme === 'light'">{{ 'check' | icon | safe }}</span>
    </button>
    <button
      type="button"
      role="menuitemradio"
      :aria-checked="$store.appearance.theme === 'dark'"
      :tabindex="$store.appearance.theme === 'dark' ? 0 : -1"
      class="theme-switcher__menu-item"
      @click="selectTheme('dark')"
      @keydown.arrow-down.prevent="focusNext(1)"
      @keydown.arrow-up.prevent="focusPrevious(1)"
      @keydown.enter.prevent="selectTheme('dark')"
      @keydown.space.prevent="selectTheme('dark')"
      @keydown.home.prevent="$refs.menu.querySelector('[role=menuitemradio]').focus()"
      @keydown.end.prevent="$refs.menu.querySelectorAll('[role=menuitemradio]')[2].focus()"
    >
      {{ 'moon' | icon | safe }}
      <span>{{ 'theme_switcher.options.dark' | t }}</span>
      <span class="theme-switcher__check" x-show="$store.appearance.theme === 'dark'">{{ 'check' | icon | safe }}</span>
    </button>
    <button
      type="button"
      role="menuitemradio"
      :aria-checked="$store.appearance.theme === 'system'"
      :tabindex="$store.appearance.theme === 'system' ? 0 : -1"
      class="theme-switcher__menu-item"
      @click="selectTheme('system')"
      @keydown.arrow-down.prevent="focusNext(2)"
      @keydown.arrow-up.prevent="focusPrevious(2)"
      @keydown.enter.prevent="selectTheme('system')"
      @keydown.space.prevent="selectTheme('system')"
      @keydown.home.prevent="$refs.menu.querySelector('[role=menuitemradio]').focus()"
      @keydown.end.prevent="$refs.menu.querySelectorAll('[role=menuitemradio]')[2].focus()"
    >
      {{ 'monitor' | icon | safe }}
      <span>{{ 'theme_switcher.options.system' | t }}</span>
      <span class="theme-switcher__check" x-show="$store.appearance.theme === 'system'">{{ 'check' | icon | safe }}</span>
    </button>
  </div>
</div>
