{% set id = uniqueId() %}

<div 
  class="theme-switcher" 
  x-data="themeSwitcher"
  x-init="themes = 
    [
      { key: 'light', label: '{{ 'theme_switcher.options.light' | t }}', icon: '{{ 'sun' | icon }}'  },
      { key: 'dark', label: '{{ 'theme_switcher.options.dark' | t }}', icon: '{{ 'moon' | icon }}'  },
      { key: 'system', label: '{{ 'theme_switcher.options.system' | t }}', icon: '{{ 'monitor' | icon }}'  }
    ]"
  x-cloak 
  lang="{% uiLang %}" 
>
  <button
    type="button"
    class="icon-btn"
    aria-label="{{ 'theme_switcher.label' | t }}"
    aria-haspopup="menu"
    aria-controls="{{ id('menu') }}"
    :aria-expanded="open"
    x-ref="trigger"
    @click="openMenu()"
  >
  {{ 'sun-moon' | icon | safe }}
  </button>

  <div class="theme-switcher__backdrop" x-show="open"></div>
  <div
    id="{{ id('menu') }}"
    role="menu"
    aria-label="{{ 'theme_switcher.label' | t }}"
    x-ref="menu"
    x-show="open"
    x-transition.origin.top.right
    class="theme-switcher__menu"
    @mousedown.prevent.self
    @keydown.prevent.escape="closeMenu()"
    @focusout="onFocusOut($event)"
  >
    <template x-for="(theme, idx) in themes">
      <div
        role="menuitemradio"
        class="theme-switcher__menu-item"
        :aria-checked="$store.appearance.theme === theme.key"
        :tabindex="focusedIdx === idx ? 0 : -1"
        :data-focused="focusedIdx === idx"
        @click="selectTheme(theme.key)"
        @mousemove="focusOnNextTick(idx)"
        @keydown.enter.prevent="selectTheme(theme.key)"
        @keydown.space.prevent="selectTheme(theme.key, { keepOpen: true })" 
        @keydown.arrow-down.prevent="focusNext()"
        @keydown.arrow-up.prevent="focusPrevious()"
      >
        <span x-html="theme.icon"></span>
        <span class="theme-switcher__menu-item-label" x-text="theme.label"></span>
        <span x-show="$store.appearance.theme === theme.key">
          {{ 'check' | icon({ width: "1em", height: "1em" }) | safe }}
        </span>
      </div>
    </template>
  </div>
</div>
